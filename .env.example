# PostgreSQL connection string used by Prisma.
# Local dev example:
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/asol_bus?schema=public"
#
# Docker one-liner:
#   docker run --name asol-pg -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=asol_bus -p 5432:5432 -d postgres:16
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/asol_bus?schema=public"
