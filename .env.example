# PostgreSQL connection string used by Prisma.
# Local dev example:
#   DATABASE_URL="file:./dev.db"
# Docker one-liner:
#   docker run --name asol-pg -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=asol_bus -p 5432:5432 -d postgres:16
DATABASE_URL="file:./dev.db"

# JWT signing secret for auth sessions. Must be at least 16 characters.
# Generate one with:
#   openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-string-minimum-16-chars"
